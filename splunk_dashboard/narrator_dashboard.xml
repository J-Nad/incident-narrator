<form version="1.1">
  <label>Incident Narrator - AI Investigation Dashboard</label>
  <description>Autonomous security investigations powered by AI. All findings are searchable in index=narrator_investigations.</description>
  
  <fieldset submitButton="false" autoRun="true">
    <input type="time" token="time_range">
      <label>Time Range</label>
      <default>
        <earliest>-7d@h</earliest>
        <latest>now</latest>
      </default>
    </input>
  </fieldset>

  <row>
    <panel>
      <title>Investigations Run</title>
      <single>
        <search>
          <query>index=narrator_investigations sourcetype=narrator:investigation 
| stats count</query>
          <earliest>$time_range.earliest$</earliest>
          <latest>$time_range.latest$</latest>
        </search>
        <option name="drilldown">none</option>
        <option name="numberPrecision">0</option>
        <option name="underLabel">Total</option>
      </single>
    </panel>
    
    <panel>
      <title>Confirmed Threats</title>
      <single>
        <search>
          <query>index=narrator_investigations sourcetype=narrator:investigation status=confirmed 
| stats count</query>
          <earliest>$time_range.earliest$</earliest>
          <latest>$time_range.latest$</latest>
        </search>
        <option name="drilldown">none</option>
        <option name="numberPrecision">0</option>
        <option name="rangeColors">["0x65A637","0xF7BC38","0xF58F39","0xD93F3C"]</option>
        <option name="rangeValues">[0,1,5]</option>
        <option name="underLabel">Status: Confirmed</option>
        <option name="useColors">1</option>
      </single>
    </panel>
    
    <panel>
      <title>Critical / High Severity</title>
      <single>
        <search>
          <query>index=narrator_investigations sourcetype=narrator:investigation (severity=critical OR severity=high)
| stats count</query>
          <earliest>$time_range.earliest$</earliest>
          <latest>$time_range.latest$</latest>
        </search>
        <option name="drilldown">none</option>
        <option name="numberPrecision">0</option>
        <option name="rangeColors">["0x65A637","0xF7BC38","0xD93F3C"]</option>
        <option name="rangeValues">[0,3]</option>
        <option name="underLabel">High Priority</option>
        <option name="useColors">1</option>
      </single>
    </panel>
    
    <panel>
      <title>Avg Confidence</title>
      <single>
        <search>
          <query>index=narrator_investigations sourcetype=narrator:investigation 
| stats avg(confidence) as avg_confidence 
| eval avg_confidence=round(avg_confidence,0)</query>
          <earliest>$time_range.earliest$</earliest>
          <latest>$time_range.latest$</latest>
        </search>
        <option name="drilldown">none</option>
        <option name="numberPrecision">0</option>
        <option name="unit">%</option>
        <option name="underLabel">Average</option>
      </single>
    </panel>
  </row>

  <row>
    <panel>
      <title>Investigations by Status</title>
      <chart>
        <search>
          <query>index=narrator_investigations sourcetype=narrator:investigation 
| stats count by status 
| sort -count</query>
          <earliest>$time_range.earliest$</earliest>
          <latest>$time_range.latest$</latest>
        </search>
        <option name="charting.chart">pie</option>
        <option name="charting.legend.placement">right</option>
      </chart>
    </panel>
    
    <panel>
      <title>Investigations by Severity</title>
      <chart>
        <search>
          <query>index=narrator_investigations sourcetype=narrator:investigation 
| stats count by severity 
| sort -count</query>
          <earliest>$time_range.earliest$</earliest>
          <latest>$time_range.latest$</latest>
        </search>
        <option name="charting.chart">column</option>
        <option name="charting.legend.placement">none</option>
        <option name="charting.fieldColors">{"critical": 0xD93F3C, "high": 0xF58F39, "medium": 0xF7BC38, "low": 0x65A637, "info": 0x6C7280}</option>
      </chart>
    </panel>
  </row>

  <row>
    <panel>
      <title>Top MITRE ATT&CK Techniques Observed</title>
      <chart>
        <search>
          <query>index=narrator_investigations sourcetype=narrator:investigation 
| mvexpand mitre_techniques 
| stats count by mitre_techniques 
| sort -count 
| head 10</query>
          <earliest>$time_range.earliest$</earliest>
          <latest>$time_range.latest$</latest>
        </search>
        <option name="charting.chart">bar</option>
        <option name="charting.legend.placement">none</option>
      </chart>
    </panel>
    
    <panel>
      <title>Confidence Distribution</title>
      <chart>
        <search>
          <query>index=narrator_investigations sourcetype=narrator:investigation 
| eval conf_bucket=case(
    confidence >= 80, "High (80-100%)",
    confidence >= 60, "Medium-High (60-79%)",
    confidence >= 40, "Medium (40-59%)",
    confidence >= 20, "Low-Medium (20-39%)",
    1=1, "Low (0-19%)"
  )
| stats count by conf_bucket</query>
          <earliest>$time_range.earliest$</earliest>
          <latest>$time_range.latest$</latest>
        </search>
        <option name="charting.chart">bar</option>
        <option name="charting.legend.placement">none</option>
      </chart>
    </panel>
  </row>

  <row>
    <panel>
      <title>Recent Investigations</title>
      <table>
        <search>
          <query>index=narrator_investigations sourcetype=narrator:investigation 
| eval alert_short=substr(alert, 1, 80)
| eval ioc_list=mvjoin(iocs, ", ")
| table _time, title, status, severity, confidence, alert_short, ioc_list, via
| sort -_time 
| head 20
| rename _time as "Timestamp", title as "Title", status as "Status", severity as "Severity", confidence as "Confidence", alert_short as "Alert", ioc_list as "IOCs", via as "Source"</query>
          <earliest>$time_range.earliest$</earliest>
          <latest>$time_range.latest$</latest>
        </search>
        <option name="drilldown">none</option>
        <option name="wrap">true</option>
        <option name="rowNumbers">false</option>
        <option name="dataOverlayMode">none</option>
        <format type="color" field="Severity">
          <colorPalette type="map">{"critical": #D93F3C, "high": #F58F39, "medium": #F7BC38, "low": #65A637, "info": #6C7280}</colorPalette>
        </format>
        <format type="color" field="Status">
          <colorPalette type="map">{"confirmed": #D93F3C, "suspected": #F58F39, "false_positive": #65A637, "inconclusive_tooling": #6C7280}</colorPalette>
        </format>
      </table>
    </panel>
  </row>

  <row>
    <panel>
      <title>Top Indicators of Compromise (Last 7 Days)</title>
      <table>
        <search>
          <query>index=narrator_investigations sourcetype=narrator:investigation status=confirmed OR status=suspected
| mvexpand iocs
| stats count by iocs
| sort -count
| head 15
| rename iocs as "Indicator", count as "Times Observed"</query>
          <earliest>-7d@h</earliest>
          <latest>now</latest>
        </search>
        <option name="drilldown">none</option>
      </table>
    </panel>
  </row>
</form>
